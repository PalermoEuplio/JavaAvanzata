<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@StyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GameWaitController">
   <children>
      <VBox alignment="CENTER" maxWidth="550.0" spacing="35.0">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="La Partita è Iniziata!" textFill="#00f0ff">
                     <font>
                        <Font name="System Bold" size="32.0" />
                     </font>
                  </Label>
                  <Label text="In attesa che i giocatori risolvano il testo cifrato..." textFill="#2980b9">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Label text="Tempo Rimanente" textFill="#ffffff">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label fx:id="timer" text="05:00" textFill="#f39c12">
                     <font>
                        <Font name="System Bold" size="48.0" />
                     </font>
                  </Label>
                  <ProgressBar fx:id="timerBar" prefHeight="15.0" prefWidth="350.0" progress="1.0" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </VBox>
            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Label text="Giocatori che hanno concluso:" textFill="#ffffff">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Label fx:id="playerCount" text="0" textFill="#27ae60">
                           <font>
                              <Font name="System Bold" size="36.0" />
                           </font>
                        </Label>
                        <Label text="/ 2" textFill="#7f8c8d">
                           <font>
                              <Font name="System Bold" size="36.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </VBox>
            
         </children>
      </VBox>
   </children>
</StackPane>
