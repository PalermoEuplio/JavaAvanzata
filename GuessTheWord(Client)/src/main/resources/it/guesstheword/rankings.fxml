<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@StyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClassificheController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1000.0" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
         </padding>
         <children>
            <Label text="🏆 CLASSIFICA GLOBALE" textFill="#00f0ff">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            
            <Button fx:id="indietro" mnemonicParsing="false" onAction="#back" text="X TORNA ALLA DASHBOARD">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
         </BorderPane.margin>
         <children>
            <HBox alignment="BOTTOM_CENTER" prefHeight="130.0" spacing="15.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: #bdc3c7; -fx-background-radius: 10 10 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, -2);">
                     <children>
                        <Label text="🥈 2° Posto" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <Label fx:id="username2" text="Username" textFill="#34495e">
                           <font>
                              <Font size="18.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="vittorie2" text="0 Vittorie" textFill="#34495e">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="130.0" prefWidth="200.0" style="-fx-background-color: #f1c40f; -fx-background-radius: 10 10 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, -5);">
                     <children>
                        <Label text="🥇 1° Posto" textFill="#8a6d3b">
                           <font>
                              <Font name="System Bold" size="20.0" />
                           </font>
                        </Label>
                        <Label fx:id="username1" text="Username" textFill="#8a6d3b">
                           <font>
                              <Font name="System Bold" size="22.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="vittorie1" text="0 Vittorie" textFill="#8a6d3b">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="15.0" />
                     </padding>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="85.0" prefWidth="170.0" style="-fx-background-color: #e67e22; -fx-background-radius: 10 10 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, -2);">
                     <children>
                        <Label text="🥉 3° Posto" textFill="#ffffff">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="username3" text="Username" textFill="#ffffff">
                           <font>
                              <Font size="16.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="vittorie3" text="0 Vittorie" textFill="#ffffff">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
            <TableView fx:id="tabellaClassifica" focusTraversable="false" prefHeight="400.0" prefWidth="200.0"  VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="posizione" prefWidth="60.0" sortable="false" text="#" />
                  <TableColumn fx:id="username" prefWidth="300.0" sortable="false" text="Username Giocatore" />
                  <TableColumn fx:id="vittorie" prefWidth="150.0" sortable="false" text="🏆 Vittorie Totali" />
                  <TableColumn fx:id="partite" prefWidth="150.0" sortable="false" text="🎮 Partite Giocate" />
                  <TableColumn fx:id="tempoMedio" prefWidth="200.0" sortable="false" text="⏱ Tempo Medio (min)" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="50.0"  BorderPane.alignment="CENTER">
         <children>
            <Label text="La tua posizione attuale nella Hall of Fame: " textFill="#ffffff">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Label fx:id="miaPosizione" text="Non Classificato" textFill="#f1c40f">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>
   </bottom>
</BorderPane>
